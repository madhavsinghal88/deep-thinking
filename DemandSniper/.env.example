# Environment Configuration
# Copy this file to .env and update the values

# Project
PROJECT_NAME=DemandSniper
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///data/demandsniper.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Scraping
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=3.0
SCRAPER_CONCURRENT_REQUESTS=3

# Email Notifications (Optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=alerts@demandsniper.com

# External APIs (Optional)
# CLEARBIT_API_KEY=your-clearbit-api-key
